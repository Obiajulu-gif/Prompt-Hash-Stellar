# PromptHash Stellar environment

# Shared runtime
STELLAR_SCAFFOLD_ENV=development
XDG_CONFIG_HOME=.config

# Frontend runtime
PUBLIC_STELLAR_NETWORK=TESTNET
PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
PUBLIC_PROMPT_HASH_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PUBLIC_STELLAR_NATIVE_ASSET_CONTRACT_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
PUBLIC_STELLAR_SIMULATION_ACCOUNT=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PUBLIC_UNLOCK_PUBLIC_KEY=BASE64_PUBLIC_KEY

# Optional external chat gateway (relative to backend or full URL)
PUBLIC_CHAT_API_BASE=

# Backend AI Service Configuration
AI_PROVIDER_URL=https://secret-ai-gateway.onrender.com
AI_API_KEY=
AI_TIMEOUT_MS=30000
AI_MAX_RETRIES=3
ENABLE_AI=true

# Serverless unlock runtime
CHALLENGE_TOKEN_SECRET=replace-with-a-long-random-secret
UNLOCK_PUBLIC_KEY=BASE64_PUBLIC_KEY
UNLOCK_PRIVATE_KEY=BASE64_PRIVATE_KEY
